# Скопировать в .env и заполнить перед первым `docker compose up`.
# НЕ коммитить .env с реальными ключами.

# --- Куда класть тома данных (КРИТИЧНО, см. ПЕРЕД-СТАРТОМ.md п.3) ---
# НЕ системный диск. Ждём подключения внешнего диска пользователем.
# Как только диск подключён — заменить на реальный путь, например D:/knowledge-factory/data
DATA_ROOT=CHANGE_ME_TO_EXTERNAL_DRIVE_PATH

# --- Postgres ---
POSTGRES_USER=kf
POSTGRES_PASSWORD=change_me
POSTGRES_DB=knowledge_factory

# --- MinIO ---
MINIO_ROOT_USER=kf_admin
MINIO_ROOT_PASSWORD=change_me_min_8_chars

# --- LLM (граф + синтез ответа) — вариант OpenRouter, через LiteLLM ---
OPENROUTER_API_KEY=
LLM_MODEL=deepseek/deepseek-v4-flash

# --- Эмбеддинги — локально (fastembed), ключ не нужен ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
MODEL_CACHE_DIR=${DATA_ROOT}/model-cache

# --- OCR / vision / видео (картинки и видео в kf.py ingest) ---
# Требует установленных системных Tesseract OCR (+ языковой пакет rus) и ffmpeg — см. ПЕРЕД-СТАРТОМ.md.
OCR_LANGUAGES=rus+eng
IMAGE_CAPTION_THRESHOLD_CHARS=20
VISION_MODEL=google/gemini-2.5-flash
VIDEO_FRAME_INTERVAL_SECONDS=15
WHISPER_MODEL_SIZE=small
# Верхний предел кадров на одно видео — ограничивает стоимость vision-API для длинных видео
# (без лимита часовое видео при интервале 15 сек дало бы 240 вызовов vision-модели).
MAX_VIDEO_FRAMES=20

# --- Синтез-заметки (осмысление контента поверх сырых чанков) ---
# Папка для LLM-заметок (о чём материал, ключевые идеи, применение),
# создаётся автоматически при первом ingest. Модель — тот же LLM_MODEL, что и для ask.
SYNTHESIS_NOTES_DIR=./Синтезированные данные (synthesized-notes)
